{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "后端：启动 Spring Boot",
      "type": "shell",
      "command": "vfox env --shell powershell | Invoke-Expression; mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "前端：启动开发服务器",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
